generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            String         @id @default(uuid())
  name          String
  code          String         @unique
  email         String?
  phone         String?
  isActive      Boolean        @default(true)
  shifts        Shift[]
  holidays      Holiday[]
  customers     Customer[]
  packages      Package[]
  olts          Olt[]
  onus          Onu[]
  ponPorts      PonPort[]
  nases         Nas[]
  ipPools       IpPool[]
  radiusServers RadiusServer[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users        User[]
  branches     Branch[]
  departments  Department[]
  designations Designation[]
  employees    Employee[]
}

model Branch {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code    String
  name    String
  address String?
  phone   String?
  email   String?

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  departments   Department[]
  employees     Employee[]
  holidays      Holiday[]
  customers     Customer[]
  nases         Nas[]
  olts          Olt[]
  onus          Onu[]
  ponPorts      PonPort[]
  ipPools       IpPool[]
  radiusServers RadiusServer[]

  @@unique([companyId, code])
}

model Department {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  code String
  name String

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([branchId, code])
}

model Designation {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code String
  name String

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([companyId, code])
}

model Employee {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  designationId String
  designation   Designation @relation(fields: [designationId], references: [id])

  employeeCode String

  firstName String
  lastName  String?
  fullName  String

  gender String?

  dateOfBirth DateTime?

  email  String?
  mobile String?

  joiningDate DateTime

  confirmationDate DateTime?

  employmentType String?

  biometricId String?

  profilePhoto String?

  bankDetails      EmployeeBank?
  salary           Decimal?                  @db.Decimal(12, 2)
  emergencyContact EmployeeEmergencyContact?

  documents   EmployeeDocument[]
  attendances Attendance[]

  managerId    String?
  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, employeeCode])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  users User[]

  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id String @id @default(uuid())

  code        String  @unique
  name        String
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  username     String @unique
  email        String @unique
  passwordHash String
  fullName     String

  isActive  Boolean   @default(true)
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeBank {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  bankName          String
  accountHolderName String
  accountNumber     String
  ifscCode          String

  branchName String?
  upiId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeEmergencyContact {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  name         String
  relationship String
  mobile       String
  address      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeDocument {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  documentType DocumentType

  fileName  String
  objectKey String

  mimeType String
  fileSize Int

  remarks String?

  uploadedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Counter {
  id    String @id @default(cuid())
  name  String @unique
  value Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  attendanceDate DateTime

  checkIn  DateTime?
  checkOut DateTime?

  workingHours  Float?
  overtimeHours Float? @default(0)

  status AttendanceStatus @default(PRESENT)

  shift ShiftType @default(GENERAL)

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
}

model Holiday {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  name        String
  holidayDate DateTime

  type HolidayType @default(COMPANY)

  recurring Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([holidayDate])
}

model Customer {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  customerCode String @unique

  firstName String
  lastName  String?

  fullName String

  mobile          String  @unique
  alternateMobile String?

  email String?

  subscriptions    Subscription[]
  connections      Connection[]
  provisioningLogs ProvisioningLog[]
  ipAddresses      IpAddress[]
  notifications Notification[]

  customerType CustomerType   @default(HOME)
  status       CustomerStatus @default(LEAD)

  installationAddress String
  village             String?
  mandal              String?
  district            String?
  state               String?
  pincode             String?

  latitude  Float?
  longitude Float?

  remarks String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([branchId])
  @@index([customerCode])
  @@index([mobile])
}

model Shift {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code String @unique
  name String

  startTime String
  endTime   String

  graceMinutes   Int  @default(10)
  halfDayMinutes Int?
  overtimeAfter  Int?

  weeklyOff String?

  isNightShift Boolean @default(false)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Package {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code String @unique
  name String

  packageType PackageType @default(HOME)

  // Bandwidth
  downloadMbps Int
  uploadMbps   Int

  // Burst (optional)
  burstDownloadMbps Int?
  burstUploadMbps   Int?

  // Pricing
  monthlyPrice Decimal @db.Decimal(10, 2)

  gstPercentage Decimal @default(18) @db.Decimal(5, 2)

  billingCycle BillingCycle @default(MONTHLY)

  validityDays Int @default(30)

  fupLimitGb Int?

  // Provisioning
  radiusGroup String?

  mikrotikProfile String?
  ciscoPolicy     String?
  huaweiProfile   String?
  zteProfile      String?
  nokiaProfile    String?

  ipPool String?

  priority Int @default(8)

  simultaneousUse Int @default(1)

  sessionTimeout Int?
  idleTimeout    Int?

  description String?

  subscriptions Subscription[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([radiusGroup])
  @@index([isActive])
}

model Subscription {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  packageId String
  package   Package @relation(fields: [packageId], references: [id])

  monthlyPrice Decimal @db.Decimal(10, 2)

  billingCycle BillingCycle @default(MONTHLY)

  installationCharge Decimal? @db.Decimal(10, 2)

  securityDeposit Decimal? @db.Decimal(10, 2)

  discountAmount Decimal? @db.Decimal(10, 2)

  billingDay Int

  startDate DateTime

  expiryDate DateTime

  autoRenew Boolean @default(true)

  status SubscriptionStatus @default(PENDING)

  remarks String?

  connections Connection[]
  billings    Billing[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([customerId])
  @@index([packageId])
  @@index([status])
}

model ProvisioningJob {
  id           String   @id @default(cuid())

  queueJobId   String?  @unique

  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id])

  action       String
  status       String

  attempts     Int      @default(0)

  startedAt    DateTime?
  completedAt  DateTime?

  error        String?

  payload       Json?
  response      Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([connectionId])
  @@index([status])
  @@index([action])
}

model Connection {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  // Network Inventory Relation
  onuId String?
  onu   Onu?    @relation(fields: [onuId], references: [id])

  nasId String?
  nas   Nas?    @relation(fields: [nasId], references: [id])
  provisioningJobs ProvisioningJob[]

  serviceType ServiceType @default(PPPOE)

  // Service Details
  connectionNumber String @unique

  pppoeUsername String @unique
  pppoePassword String

  vlanId Int?

  staticIp String?

  macAddress String?

  installationDate DateTime?

  activationDate DateTime?

  disconnectedDate DateTime?

  // Audit
  installedBy String?
  activatedBy String?

  lastSyncAt DateTime?

  status ConnectionStatus @default(PENDING)

  remarks          String?
  ipAddresses      IpAddress[]
  provisioningLogs ProvisioningLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([customerId])
  @@index([subscriptionId])
  @@index([onuId])
  @@index([nasId])
  @@index([pppoeUsername])
  @@index([connectionNumber])
}

model Billing {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  billingMonth Int
  billingYear  Int

  invoiceNumber String   @unique
  invoiceDate   DateTime @default(now())

  amount Decimal @db.Decimal(10, 2)

  gstPercentage Decimal @default(18) @db.Decimal(5, 2)
  gstAmount     Decimal @db.Decimal(10, 2)

  totalAmount Decimal @db.Decimal(10, 2)

  dueDate DateTime

  paidDate DateTime?

  status BillingStatus @default(PENDING)

  remarks String?

  payments Payment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([subscriptionId, billingMonth, billingYear])
  @@index([status])
}

model Payment {
  id String @id @default(uuid())

  billingId String
  billing   Billing @relation(fields: [billingId], references: [id])

  receiptNumber String @unique

  amount Decimal @db.Decimal(10, 2)

  paymentMethod PaymentMethod

  transactionId String?

  paymentDate DateTime @default(now())

  collectedBy String?

  remarks String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([billingId])
  @@index([paymentDate])
}

model Olt {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  name   String
  vendor OltVendor

  model String

  managementIp String

  snmpCommunity String?

  sshPort Int @default(22)

  location String?

  onus     Onu[]
  ponPorts PonPort[]

  status OltStatus @default(ACTIVE)

  remarks String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, name])
  @@unique([companyId, managementIp])
  @@index([companyId])
  @@index([branchId])
}

model Onu {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  oltId String
  olt   Olt    @relation(fields: [oltId], references: [id])

  serialNumber String    @unique
  vendor       OnuVendor
  model        String

  ponPortId String
  ponPort   PonPort @relation(fields: [ponPortId], references: [id])
  onuId     Int

  macAddress String?

  status OnuStatus @default(OFFLINE)

  rxPower Float?
  txPower Float?

  distance Float?

  installedAt DateTime?

  remarks     String?
  connections Connection[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([ponPortId, onuId])
  @@index([companyId])
  @@index([branchId])
  @@index([oltId])
}

model PonPort {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  oltId String
  olt   Olt    @relation(fields: [oltId], references: [id])

  name       String // GPON1/1
  portNumber Int // 1
  splitter   String? // 1:64
  capacity   Int     @default(64)

  status PonPortStatus @default(ACTIVE)

  remarks String?

  onus Onu[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([oltId, portNumber])
  @@unique([oltId, name])
  @@index([companyId])
  @@index([branchId])
  @@index([oltId])
}

model Nas {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  name   String
  vendor NasVendor

  ipAddress String

  username String
  password String

  apiPort Int?
  sshPort Int  @default(22)

  isActive Boolean @default(true)

  remarks     String?
  description String?

  radiusEnabled Boolean @default(false)

  apiProtocol String?
  apiTimeout  Int     @default(30)

  location String?

  lastSyncAt DateTime?

  createdBy String?
  updatedBy String?

  defaultIpPoolId String?
  defaultIpPool   IpPool? @relation("NasDefaultIpPool", fields: [defaultIpPoolId], references: [id])

  ipPools     IpPool[]     @relation("NasIpPools")
  connections Connection[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model IpPool {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  nasId String?
  nas   Nas?    @relation("NasIpPools", fields: [nasId], references: [id])

  defaultNas Nas[] @relation("NasDefaultIpPool")

  name String

  network    String
  subnetMask Int

  gateway String

  startIp String
  endIp   String

  dns1 String?
  dns2 String?

  vlanId Int?

  isActive Boolean @default(true)

  remarks     String?
  description String?

  createdBy String?
  updatedBy String?

  deletedAt DateTime?

  ipAddresses IpAddress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([nasId])
}

model RadiusServer {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  name String

  host String

  authPort Int @default(1812)

  acctPort Int @default(1813)

  coaPort Int @default(3799)

  secret String

  timeout Int @default(30)

  isActive Boolean @default(true)

  version String?

  description String?
  remarks     String?

  createdBy String?
  updatedBy String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
}

model IpAddress {
  id String @id @default(uuid())

  ipPoolId String
  ipPool   IpPool @relation(fields: [ipPoolId], references: [id])

  ipAddress String

  status IpAddressStatus @default(FREE)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id])

  assignedAt DateTime?

  releasedAt DateTime?

  assignedBy String?

  leasedUntil DateTime?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ipPoolId, ipAddress])
  @@index([status])
}

model ProvisioningLog {
  id String @id @default(uuid())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id])

  action ProvisioningAction

  status ProvisioningStatus

  message String?

  executedBy String?

  executedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([connectionId])
  @@index([executedAt])
}

model RadiusCheck {
  id        Int    @id @default(autoincrement())
  username  String @map("username")
  attribute String @map("attribute")
  op        String @default(":=") @map("op")
  value     String @map("value")

  @@map("radcheck")
}

model RadiusReply {
  id        Int    @id @default(autoincrement())
  username  String @map("username")
  attribute String @map("attribute")
  op        String @default(":=") @map("op")
  value     String @map("value")

  @@map("radreply")
}

model RadiusUserGroup {
  username  String @map("username")
  groupname String @map("groupname")
  priority  Int    @default(1)

  @@id([username, groupname])
  @@map("radusergroup")
}

model RadiusGroupReply {
  id        Int    @id @default(autoincrement())
  groupname String @map("groupname")
  attribute String @map("attribute")
  op        String @default(":=") @map("op")
  value     String @map("value")

  @@map("radgroupreply")
}

model RadiusNas {
  id          Int     @id @default(autoincrement())
  nasname     String
  shortname   String?
  type        String?
  ports       Int?
  secret      String
  server      String?
  community   String?
  description String?

  @@map("nas")
}

model Notification {
  id String @id @default(uuid())

  customerId String?
  customer Customer? @relation(fields: [customerId], references: [id])

  employeeId String?

  title String
  message String

  type NotificationType

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([isRead])
  @@index([type])
}

enum IpAddressStatus {
  FREE
  RESERVED
  ASSIGNED
}

enum NasVendor {
  MIKROTIK
  CISCO
  JUNIPER
  HUAWEI
}

enum ServiceType {
  PPPOE
  HOTSPOT
  STATIC
}

enum DocumentType {
  PROFILE_PHOTO
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
  RESUME
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_CERTIFICATE
  EDUCATION_CERTIFICATE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HOLIDAY
  HALF_DAY
}

enum ShiftType {
  GENERAL
  MORNING
  EVENING
  NIGHT
}

enum HolidayType {
  NATIONAL
  STATE
  COMPANY
  OPTIONAL
}

enum CustomerType {
  HOME
  BUSINESS
  ENTERPRISE
  GOVERNMENT
}

enum CustomerStatus {
  LEAD
  PENDING_INSTALLATION
  ACTIVE
  SUSPENDED
  DISCONNECTED
  TERMINATED
}

enum PackageType {
  HOME
  BUSINESS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISCONNECTED
}

enum BillingStatus {
  PENDING
  GENERATED
  PAID
  OVERDUE
  CANCELLED
}

enum OltVendor {
  ZTE
  HUAWEI
  NOKIA
  FIBERHOME
  DASAN
}

enum OltStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
}

enum OnuStatus {
  ONLINE
  OFFLINE
  DISABLED
}

enum OnuVendor {
  ZTE
  HUAWEI
  NOKIA
  FIBERHOME
  VSOL
  TP_LINK
  UFIBER
  OTHER
}

enum PonPortStatus {
  ACTIVE
  DISABLED
  MAINTENANCE
}

enum PaymentMethod {
  CASH
  UPI
  PHONEPE
  GOOGLEPAY
  PAYTM
  BANK_TRANSFER
  CHEQUE
  CREDIT_CARD
  DEBIT_CARD
  ONLINE
}

enum ProvisioningStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ProvisioningAction {
  CREATE_CONNECTION
  CREATE_RADIUS_USER
  UPDATE_RADIUS_PASSWORD
  DELETE_RADIUS_USER
  ASSIGN_RADIUS_GROUP
  REMOVE_RADIUS_GROUP
  ALLOCATE_IP
  RELEASE_IP
  MIKROTIK_PROVISION
  MIKROTIK_DISABLE
  MIKROTIK_ENABLE
  OLT_PROVISION
  OLT_DEPROVISION
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}
