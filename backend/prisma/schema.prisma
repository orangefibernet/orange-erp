generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  email    String?
  phone    String?
  isActive Boolean @default(true)
  shifts Shift[]
  holidays Holiday[]
  customers Customer[]
  packages Package[]
  olts Olt[]
  onus Onu[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users        User[]
  branches     Branch[]
  departments  Department[]
  designations Designation[]
  employees    Employee[]
}

model Branch {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code    String
  name    String
  address String?
  phone   String?
  email   String?

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  departments Department[]
  employees   Employee[]
  holidays Holiday[]
  customers Customer[]
  olts Olt[]
  onus Onu[]

  @@unique([companyId, code])
}

model Department {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  code String
  name String

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([branchId, code])
}

model Designation {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code String
  name String

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([companyId, code])
}

model Employee {
  id String @id @default(uuid())

  companyId String
  company Company @relation(fields: [companyId], references: [id])

  branchId String
  branch Branch @relation(fields: [branchId], references: [id])

  departmentId String
  department Department @relation(fields: [departmentId], references: [id])

  designationId String
  designation Designation @relation(fields: [designationId], references: [id])

  employeeCode String

  firstName String
  lastName String?
  fullName String

  gender String?

  dateOfBirth DateTime?

  email String?
  mobile String?

  joiningDate DateTime

  confirmationDate DateTime?

  employmentType String?

  biometricId String?

  profilePhoto String?
  
  bankDetails EmployeeBank?
  salary Decimal? @db.Decimal(12,2)
  emergencyContact EmployeeEmergencyContact?

  documents EmployeeDocument[]
  attendances Attendance[]

  managerId String?
  manager Employee? @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([companyId, employeeCode])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  users User[]

  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String @id @default(uuid())

  code        String @unique
  name        String
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  username     String @unique
  email        String @unique
  passwordHash String
  fullName     String

  isActive  Boolean   @default(true)
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model EmployeeBank {
  id String @id @default(uuid())

  employeeId String @unique
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  bankName String
  accountHolderName String
  accountNumber String
  ifscCode String

  branchName String?
  upiId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeEmergencyContact {
  id String @id @default(uuid())

  employeeId String @unique
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  name String
  relationship String
  mobile String
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeDocument {
  id String @id @default(uuid())

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  documentType DocumentType

  fileName String
  objectKey String

  mimeType String
  fileSize Int

  remarks String?

  uploadedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Counter {
  id        String   @id @default(cuid())
  name      String   @unique
  value     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id              String             @id @default(uuid())
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id])

  attendanceDate  DateTime

  checkIn         DateTime?
  checkOut        DateTime?

  workingHours    Float?
  overtimeHours   Float? @default(0)

  status          AttendanceStatus   @default(PRESENT)

  shift           ShiftType          @default(GENERAL)

  remarks         String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
}

model Holiday {
  id          String      @id @default(uuid())

  companyId   String
  company      Company     @relation(fields: [companyId], references: [id])

  branchId    String?
  branch       Branch?     @relation(fields: [branchId], references: [id])

  name         String
  holidayDate  DateTime

  type         HolidayType @default(COMPANY)

  recurring    Boolean     @default(false)

  isActive     Boolean     @default(true)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([holidayDate])
}

model Customer {
  id                String           @id @default(uuid())

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])

  branchId          String
  branch            Branch           @relation(fields: [branchId], references: [id])

  customerCode      String           @unique

  firstName         String
  lastName          String?

  fullName          String

  mobile            String           @unique
  alternateMobile   String?

  email             String?

  subscriptions Subscription[]
  connections Connection[]

  customerType      CustomerType     @default(HOME)
  status            CustomerStatus   @default(LEAD)

  installationAddress String
  village           String?
  mandal            String?
  district          String?
  state             String?
  pincode           String?

  latitude          Float?
  longitude         Float?

  remarks           String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([branchId])
  @@index([customerCode])
  @@index([mobile])
}
model Shift {
  id             String   @id @default(uuid())

  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])

  code           String   @unique
  name           String

  startTime      String
  endTime        String

  graceMinutes   Int      @default(10)
  halfDayMinutes Int?
  overtimeAfter  Int?

  weeklyOff      String?

  isNightShift   Boolean  @default(false)
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
}

model Package {
  id             String        @id @default(uuid())

  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])

  code           String        @unique
  name           String

  packageType    PackageType   @default(HOME)

  downloadMbps   Int
  uploadMbps     Int

  monthlyPrice   Decimal       @db.Decimal(10,2)

  gstPercentage  Decimal       @default(18) @db.Decimal(5,2)

  billingCycle   BillingCycle  @default(MONTHLY)

  validityDays   Int           @default(30)

  fupLimitGb     Int?

  description    String?

  subscriptions Subscription[]

  isActive       Boolean       @default(true)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([companyId])
}

model Subscription {
  id                  String               @id @default(uuid())

  customerId          String
  customer            Customer             @relation(fields: [customerId], references: [id])

  packageId           String
  package             Package              @relation(fields: [packageId], references: [id])

  monthlyPrice        Decimal              @db.Decimal(10,2)

  installationCharge  Decimal?             @db.Decimal(10,2)

  securityDeposit     Decimal?             @db.Decimal(10,2)

  discountAmount      Decimal?             @db.Decimal(10,2)

  billingDay          Int

  startDate           DateTime

  expiryDate          DateTime

  autoRenew           Boolean              @default(true)

  status              SubscriptionStatus   @default(PENDING)

  remarks             String?

  connections Connection[]
  billings Billing[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@index([customerId])
  @@index([packageId])
  @@index([status])
}

model Connection {
  id                 String   @id @default(uuid())

  customerId         String
  customer           Customer @relation(fields: [customerId], references: [id])

  subscriptionId     String
  subscription       Subscription @relation(fields: [subscriptionId], references: [id])

  pppoeUsername      String   @unique
  pppoePassword      String

  oltName            String?
  ponPort            String?

  onuSerialNumber    String?

  vlanId             Int?

  staticIp           String?

  macAddress         String?

  installationDate   DateTime?

  activationDate     DateTime?

  status             ConnectionStatus @default(PENDING)

  remarks            String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([customerId])
  @@index([subscriptionId])
  @@index([pppoeUsername])
}

model Billing {
  id             String        @id @default(uuid())

  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])

  billingMonth   Int
  billingYear    Int

  invoiceNumber  String        @unique

  amount         Decimal       @db.Decimal(10,2)
  gstAmount      Decimal       @db.Decimal(10,2)

  totalAmount    Decimal       @db.Decimal(10,2)

  dueDate        DateTime

  paidDate       DateTime?

  status         BillingStatus @default(PENDING)

  remarks        String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@unique([subscriptionId, billingMonth, billingYear])
  @@index([status])
}

model Olt {
  id          String      @id @default(uuid())

  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])

  branchId    String?
  branch      Branch?     @relation(fields: [branchId], references: [id])

  name        String
  vendor      OltVendor

  model       String

  managementIp String

  snmpCommunity String?

  sshPort     Int @default(22)

  location    String?

  onus Onu[]

  status      OltStatus @default(ACTIVE)

  remarks     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@unique([companyId, managementIp])

  @@index([companyId])
  @@index([branchId])
}

model Onu {
  id            String      @id @default(uuid())

  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])

  branchId      String?
  branch        Branch?     @relation(fields: [branchId], references: [id])

  oltId         String
  olt           Olt         @relation(fields: [oltId], references: [id])

  serialNumber  String      @unique
  vendor        OnuVendor
  model         String

  ponPort       Int
  onuId         Int

  macAddress    String?

  status        OnuStatus   @default(OFFLINE)

  rxPower       Float?
  txPower       Float?

  distance      Float?

  installedAt   DateTime?

  remarks       String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@unique([oltId, ponPort, onuId])

  @@index([companyId])
  @@index([branchId])
  @@index([oltId])
}

enum DocumentType {
  PROFILE_PHOTO
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
  RESUME
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_CERTIFICATE
  EDUCATION_CERTIFICATE
  OTHER
}
enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HOLIDAY
  HALF_DAY
}

enum ShiftType {
  GENERAL
  MORNING
  EVENING
  NIGHT
}
enum HolidayType {
  NATIONAL
  STATE
  COMPANY
  OPTIONAL
}
enum CustomerType {
  HOME
  BUSINESS
  ENTERPRISE
  GOVERNMENT
}

enum CustomerStatus {
  LEAD
  PENDING_INSTALLATION
  ACTIVE
  SUSPENDED
  DISCONNECTED
  TERMINATED
}
enum PackageType {
  HOME
  BUSINESS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}
enum SubscriptionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
}
enum ConnectionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISCONNECTED
}
enum BillingStatus {
  PENDING
  GENERATED
  PAID
  OVERDUE
  CANCELLED
}

enum OltVendor {
  ZTE
  HUAWEI
  NOKIA
  FIBERHOME
  DASAN
}

enum OltStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
}

enum OnuStatus {
  ONLINE
  OFFLINE
  DISABLED
}

enum OnuVendor {
  ZTE
  HUAWEI
  NOKIA
  FIBERHOME
  VSOL
  TP_LINK
  UFIBER
  OTHER
}